---
---

<section class="border-t border-clef-border py-10" aria-label="Documentation and resources">
  <div class="mx-auto max-w-[1200px] px-6">
    <div
      class="grid items-center gap-8 rounded-[10px] border border-clef-border bg-clef-panel px-8 py-7 sm:grid-cols-[1fr_auto]"
    >
      <div>
        <div class="mb-1.5 text-[17px] font-semibold text-clef-text">
          Learn how teams manage secrets with Clef
        </div>
        <p class="text-sm leading-relaxed text-clef-textSecondary">
          Quick-start guide, CLI reference, manifest schema docs, and
          architecture notes — everything you need to set up secrets management
          in minutes.
        </p>
      </div>
      <div class="flex shrink-0 flex-wrap gap-2.5">
        <a
          href="https://docs.clef.sh"
          class="inline-flex items-center gap-2 rounded-md border border-clef-accent bg-clef-accent px-4.5 py-2 text-[13px] font-semibold text-clef-bg transition-opacity hover:opacity-[0.88]"
        >
          Documentation
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a
          href="https://github.com/clef-sh/clef"
          class="inline-flex items-center gap-2 rounded-md border border-clef-borderMid bg-transparent px-4.5 py-2 text-[13px] font-medium text-clef-textSecondary no-underline transition-colors hover:border-clef-textSecondary hover:text-clef-text"
        >
          GitHub
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
