{
  "name": "@clef-sh/ui",
  "version": "0.1.17",
  "description": "Local web UI for Clef — git-native secrets management",
  "repository": {
    "type": "git",
    "url": "https://github.com/clef-sh/clef",
    "directory": "packages/ui"
  },
  "main": "dist/server/index.js",
  "types": "dist/server/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./package.json": "./package.json",
    "./client": {
      "types": "./dist/client-lib/index.d.ts",
      "default": "./src/client/index.ts"
    }
  },
  "files": [
    "dist",
    "src/client"
  ],
  "scripts": {
    "build": "npm run build:client && npm run build:server && npm run build:client-lib",
    "build:client": "vite build",
    "build:server": "tsc",
    "build:client-lib": "tsc -p tsconfig.client.json",
    "dev": "vite",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@clef-sh/core": "*",
    "express": "^5.1.0",
    "express-rate-limit": "^7.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.39",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT",
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.59.0"
  }
}
