# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Astro / Wrangler generated files
www/.astro/
www/.wrangler/

# Generated API docs (typedoc output, rebuilt by docs:api)
docs/api/

# Coverage
coverage/
.nyc_output/

# Environment
.env
.env.*
!.env.example

# Decrypted artifacts (must never be committed)
*.dec.yaml
*.dec.json
*.decrypted.yaml
*.decrypted.json

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.idea/
*.iml

# Logs
*.log
npm-debug.log*

# SOPS age key files (local only)
.sops/keys.txt

# Clef metadata files (*.clef-meta.yaml) are intentionally
# committed — they track pending secret state.
# Do NOT add *.clef-meta.yaml here.
.development

platforms/*/bin/sops

# SEA config (generated during build:sea)
packages/cli/sea-config.json
packages/agent/sea-config.json

# Blackbox test runs
.blackbox-runs/

cache
docs/.vitepress/cache

test-results/
playwright-report/
docs/plans
blog