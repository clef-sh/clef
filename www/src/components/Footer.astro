---
---

<footer class="border-t border-clef-border py-12">
  <div class="mx-auto flex max-w-[1200px] flex-col items-center gap-6 px-6">
    <!-- Logo -->
    <a
      href="/"
      class="font-mono text-sm font-bold tracking-wider text-clef-text"
    >
      clef<span class="text-clef-accent">.</span>sh
    </a>

    <!-- Nav links -->
    <nav class="flex gap-6" aria-label="Footer">
      <a
        href="https://github.com/clef-sh/clef"
        class="text-[13px] text-clef-textSecondary transition-colors hover:text-clef-text"
      >
        GitHub
      </a>
      <a
        href="https://docs.clef.sh"
        class="text-[13px] text-clef-textSecondary transition-colors hover:text-clef-text"
      >
        Documentation
      </a>
      <a
        href="https://registry.clef.sh"
        class="text-[13px] text-clef-textSecondary transition-colors hover:text-clef-text"
      >
        Broker Registry
      </a>
      <a
        href="https://docs.clef.sh/guide/introduction"
        class="text-[13px] text-clef-textSecondary transition-colors hover:text-clef-text"
      >
        Guide
      </a>
      <a
        href="https://github.com/clef-sh/clef/blob/main/whitepaper.md"
        class="text-[13px] text-clef-textSecondary transition-colors hover:text-clef-text"
      >
        Whitepaper
      </a>
    </nav>

    <!-- Copyright -->
    <p class="text-[12px] text-clef-textMuted">
      &copy; {new Date().getFullYear()} Clef &middot; MIT License
    </p>
  </div>
</footer>
