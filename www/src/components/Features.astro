---
---

<section
  class="border-t border-clef-border py-20"
  aria-labelledby="features-heading"
>
  <div class="mx-auto max-w-[1200px] px-6">
    <!-- Section header -->
    <div class="mb-10">
      <div
        class="mb-3 font-mono text-[11px] font-medium uppercase tracking-[0.1em] text-clef-accent"
      >
        Features
      </div>
      <h2
        id="features-heading"
        class="mb-2.5 text-[32px] font-bold tracking-tight text-clef-text"
      >
        Why Clef?
      </h2>
      <p class="text-[15px] leading-relaxed text-clef-textSecondary">
        Everything your team needs to manage encrypted secrets — without leaving
        the repo.
      </p>
    </div>

    <!-- Features grid -->
    <div
      class="grid gap-px overflow-hidden rounded-[10px] border border-clef-border bg-clef-border sm:grid-cols-2 lg:grid-cols-3"
    >
      <!-- Feature 1 -->
      <div class="bg-clef-panel p-8 transition-colors hover:bg-clef-surface">
        <svg
          class="mb-4 h-8 w-8 text-clef-textMuted"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4" />
          <line x1="1.05" y1="12" x2="7" y2="12" />
          <line x1="17.01" y1="12" x2="22.96" y2="12" />
        </svg>
        <div class="mb-2 text-base font-semibold text-clef-text">
          Git-native
        </div>
        <p class="text-[13px] leading-relaxed text-clef-textSecondary">
          Every secret lives in your repo as an encrypted file. No external
          state, no database, no server to run. Version history comes free via
          git.
        </p>
      </div>

      <!-- Feature 2 -->
      <div class="bg-clef-panel p-8 transition-colors hover:bg-clef-surface">
        <svg
          class="mb-4 h-8 w-8 text-clef-textMuted"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <rect x="3" y="3" width="7" height="7" />
          <rect x="14" y="3" width="7" height="7" />
          <rect x="3" y="14" width="7" height="7" />
          <rect x="14" y="14" width="7" height="7" />
        </svg>
        <div class="mb-2 text-base font-semibold text-clef-text">
          Namespace &times; Environment Matrix
        </div>
        <p class="text-[13px] leading-relaxed text-clef-textSecondary">
          Organise secrets by service and deployment stage. Instantly see key
          drift between dev, staging, and production in a single colour-coded
          grid.
        </p>
      </div>

      <!-- Feature 3 -->
      <div class="bg-clef-panel p-8 transition-colors hover:bg-clef-surface">
        <svg
          class="mb-4 h-8 w-8 text-clef-textMuted"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path
            d="M22 11.08V12a10 10 0 1 1-5.93-9.14"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <polyline
            points="22 4 12 14.01 9 11.01"
            stroke-linecap="round"
            stroke-linejoin="round"></polyline>
        </svg>
        <div class="mb-2 text-base font-semibold text-clef-text">
          Schema Validation
        </div>
        <p class="text-[13px] leading-relaxed text-clef-textSecondary">
          Define required keys, types, and patterns per namespace. Lint your
          entire repo in one command and catch misconfigurations before they
          reach production.
        </p>
      </div>

      <!-- Feature 4 -->
      <div class="bg-clef-panel p-8 transition-colors hover:bg-clef-surface">
        <svg
          class="mb-4 h-8 w-8 text-clef-textMuted"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
        <div class="mb-2 text-base font-semibold text-clef-text">
          Works with Your KMS
        </div>
        <p class="text-[13px] leading-relaxed text-clef-textSecondary">
          Supports age, AWS KMS, GCP KMS, and PGP out of the box. The SOPS
          binary handles all encryption — Clef never touches your keys
          directly.
        </p>
      </div>

      <!-- Feature 5 -->
      <div class="bg-clef-panel p-8 transition-colors hover:bg-clef-surface">
        <svg
          class="mb-4 h-8 w-8 text-clef-textMuted"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <rect x="4" y="5" width="16" height="12" rx="2" stroke-width="1.5" />
          <path d="M8 20h8" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        <div class="mb-2 text-base font-semibold text-clef-text">
          Local Web UI
        </div>
        <p class="text-[13px] leading-relaxed text-clef-textSecondary">
          Run <code class="font-mono text-clef-accent">clef ui</code> to
          launch a full-featured browser interface at
          <code class="font-mono">127.0.0.1:7777</code>. Edit, diff, and lint
          secrets without leaving your browser.
        </p>
      </div>

      <!-- Feature 6 -->
      <div class="bg-clef-panel p-8 transition-colors hover:bg-clef-surface">
        <svg
          class="mb-4 h-8 w-8 text-clef-textMuted"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path
            d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <div class="mb-2 text-base font-semibold text-clef-text">
          Lint &amp; Drift Detection
        </div>
        <p class="text-[13px] leading-relaxed text-clef-textSecondary">
          Automated checks for missing keys, schema violations, and
          cross-environment drift. Run in CI to enforce policy or locally to
          catch issues early.
        </p>
      </div>
    </div>
  </div>
</section>
