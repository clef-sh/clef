{
  "name": "@clef-sh/cli",
  "version": "0.1.11-beta.71",
  "description": "CLI for Clef — git-native secrets management",
  "repository": {
    "type": "git",
    "url": "https://github.com/clef-sh/clef",
    "directory": "packages/cli"
  },
  "main": "dist/index.cjs",
  "exports": {
    "import": "./dist/index.mjs",
    "require": "./dist/index.cjs"
  },
  "bin": {
    "clef": "bin/clef.js"
  },
  "files": [
    "dist/index.mjs",
    "dist/index.mjs.map",
    "dist/index.cjs",
    "dist/index.cjs.map",
    "dist/client",
    "bin"
  ],
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs",
    "build:sea": "tsc --noEmit && node scripts/build.mjs --sea",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {},
  "optionalDependencies": {
    "@clef-sh/sops-darwin-arm64": "3.9.4",
    "@clef-sh/sops-darwin-x64": "3.9.4",
    "@clef-sh/sops-linux-x64": "3.9.4",
    "@clef-sh/sops-linux-arm64": "3.9.4",
    "@clef-sh/sops-win32-x64": "3.9.4"
  },
  "devDependencies": {
    "@clef-sh/core": "*",
    "@clef-sh/ui": "*",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "commander": "^12.0.0",
    "esbuild": "^0.27.4",
    "postject": "^1.0.0-alpha.6",
    "jest": "^29.7.0",
    "picocolors": "^1.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.9.3",
    "yaml": "^2.8.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT"
}
