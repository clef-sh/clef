{
  "name": "@clef-sh/cli",
  "version": "0.1.28",
  "description": "CLI for Clef — git-native secrets management",
  "repository": {
    "type": "git",
    "url": "https://github.com/clef-sh/clef",
    "directory": "packages/cli"
  },
  "main": "dist/index.cjs",
  "exports": {
    "import": "./dist/index.mjs",
    "require": "./dist/index.cjs"
  },
  "bin": {
    "clef": "bin/clef.js"
  },
  "files": [
    "dist/index.mjs",
    "dist/index.mjs.map",
    "dist/index.cjs",
    "dist/index.cjs.map",
    "dist/client",
    "bin",
    "templates"
  ],
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs",
    "build:sea": "tsc --noEmit && node scripts/build.mjs --sea",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@clef-sh/agent": "0.1.28",
    "@clef-sh/analytics": "0.1.33",
    "@clef-sh/cloud": "0.1.34",
    "@clef-sh/core": "0.1.28",
    "@clef-sh/pack-aws-parameter-store": "0.1.8",
    "@clef-sh/pack-aws-secrets-manager": "0.1.8",
    "@clef-sh/runtime": "0.1.31",
    "@clef-sh/ui": "0.1.28"
  },
  "optionalDependencies": {
    "@clef-sh/keyservice-darwin-arm64": "^0.1.9",
    "@clef-sh/keyservice-darwin-x64": "^0.1.9",
    "@clef-sh/keyservice-linux-arm64": "^0.1.9",
    "@clef-sh/keyservice-linux-x64": "^0.1.9",
    "@clef-sh/keyservice-win32-x64": "^0.1.9",
    "@clef-sh/sops-darwin-arm64": "3.12.2",
    "@clef-sh/sops-darwin-x64": "3.12.2",
    "@clef-sh/sops-linux-arm64": "3.12.2",
    "@clef-sh/sops-linux-x64": "3.12.2",
    "@clef-sh/sops-win32-x64": "3.12.2"
  },
  "devDependencies": {
    "@types/diff": "^5.2.3",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.39",
    "commander": "^12.0.0",
    "diff": "^5.2.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "picocolors": "^1.0.0",
    "postject": "^1.0.0-alpha.6",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "yaml": "^2.8.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT"
}
