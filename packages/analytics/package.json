{
  "name": "@clef-sh/analytics",
  "version": "0.1.19-alpha.94",
  "description": "CLI analytics for Clef — powered by PostHog, fully opt-out",
  "repository": {
    "type": "git",
    "url": "https://github.com/clef-sh/clef",
    "directory": "packages/analytics"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "posthog-node": "^4.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "esbuild": "^0.27.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT"
}
