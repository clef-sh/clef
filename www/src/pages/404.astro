---
import "../styles/global.css";

// Same self-hosted preload pattern as the index page — see index.astro
// for the full rationale.
import sansLatinUrl from "@fontsource-variable/instrument-sans/files/instrument-sans-latin-wght-normal.woff2?url";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 — Page not found | Clef</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href={sansLatinUrl} as="font" type="font/woff2" crossorigin />
  </head>
  <body
    class="flex min-h-screen flex-col items-center justify-center bg-clef-bg font-sans text-clef-text antialiased"
  >
    <div class="text-center">
      <p class="text-6xl font-bold text-clef-accent">404</p>
      <h1 class="mt-4 text-2xl font-semibold text-clef-text">
        Page not found
      </h1>
      <p class="mt-2 text-clef-textMuted">
        The page you are looking for does not exist or has been moved.
      </p>
      <a
        href="/"
        class="mt-8 inline-block rounded-md bg-clef-accent px-5 py-2.5 text-sm font-medium text-clef-bg transition-colors hover:bg-clef-accentHover"
      >
        Back to home
      </a>
    </div>
  </body>
</html>
