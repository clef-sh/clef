{
  "name": "clef",
  "version": "0.1.0",
  "private": true,
  "description": "Git-native config and secrets management built on Mozilla SOPS",
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/ui",
    "packages/agent"
  ],
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:integration": "cd integration && npm test",
    "test:e2e": "npm run build -w packages/core && npm run build -w packages/ui && npm run build:sea -w packages/cli && cd e2e && npm ci && npx playwright install --with-deps chromium && npx playwright test",
    "format": "prettier --write . && npm run format --workspaces --if-present",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "build": "npm run build -w packages/core && npm run build -w packages/ui && npm run build -w packages/agent && npm run build -w packages/cli",
    "docs:api": "typedoc",
    "docs:build": "npm run docs:api && vitepress build docs",
    "docs:dev": "npm run docs:api && vitepress dev docs",
    "prepublish": "npm run build",
    "publish": "npm publish --workspaces"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clef-sh/clef.git"
  },
  "homepage": "https://clef.sh",
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.39.0",
    "prettier": "^3.2.0",
    "semantic-release": "^24.0.0",
    "semantic-release-monorepo": "^8.0.2",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.4.0",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
