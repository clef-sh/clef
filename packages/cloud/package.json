{
  "name": "@clef-sh/cloud",
  "version": "0.1.32-beta.183",
  "description": "Clef Cloud integration — managed KMS, device-flow auth, artifact hosting",
  "repository": {
    "type": "git",
    "url": "https://github.com/clef-sh/clef",
    "directory": "packages/cloud"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./cli": {
      "import": {
        "types": "./dist/cli.d.mts",
        "default": "./dist/cli.mjs"
      },
      "require": {
        "types": "./dist/cli.d.ts",
        "default": "./dist/cli.js"
      }
    },
    "./ui": {
      "import": {
        "types": "./dist/ui/index.d.mts",
        "default": "./dist/ui/index.mjs"
      },
      "require": {
        "types": "./dist/ui/index.d.ts",
        "default": "./dist/ui/index.js"
      }
    }
  },
  "typesVersions": {
    "*": {
      "cli": [
        "dist/cli.d.ts"
      ],
      "ui": [
        "dist/ui/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  },
  "peerDependencies": {
    "@clef-sh/core": "0.1.26-beta.183"
  },
  "peerDependenciesMeta": {
    "@clef-sh/core": {
      "optional": false
    }
  },
  "devDependencies": {
    "@clef-sh/core": "0.1.26-beta.183",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.39",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT"
}
