---
---

<section
  id="how-it-works"
  class="border-t border-clef-border py-20"
  aria-labelledby="how-it-works-heading"
>
  <div class="mx-auto max-w-300 px-6">
    <!-- Section header -->
    <div class="mb-10">
      <div
        class="mb-3 font-mono text-[11px] font-medium uppercase tracking-widest text-clef-accent"
      >
        How it works
      </div>
      <h2
        id="how-it-works-heading"
        class="mb-2.5 text-[32px] font-bold tracking-tight text-clef-text"
      >
        Init. Manage. Validate.
      </h2>
      <p class="text-[15px] leading-relaxed text-clef-textSecondary">
        Get your secrets organised in three steps — all from the CLI or
        the local UI.
      </p>
    </div>

    <!-- Steps grid -->
    <div
      class="grid gap-px overflow-hidden rounded-[10px] border border-clef-border bg-clef-border sm:grid-cols-3"
    >
      <!-- Step 1 -->
      <div class="bg-clef-panel p-8">
        <div
          class="mb-4 font-mono text-[11px] uppercase tracking-wider text-clef-accent"
        >
          01 — Init
        </div>
        <svg
          class="mb-4 h-9 w-9 text-clef-accent"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <rect x="4" y="5" width="16" height="12" rx="2" stroke-width="1.5" />
          <path d="M8 20h8" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        <div class="mb-2.5 text-[17px] font-semibold text-clef-text">
          Create your manifest in seconds.
        </div>
        <p class="text-sm leading-relaxed text-clef-textSecondary">
          Run <code class="font-mono text-clef-accent">clef init</code> to
          scaffold a <code class="font-mono">clef.yaml</code> manifest. Declare
          your namespaces, environments, and encryption backend — Clef handles
          the rest.
        </p>
        <div
          class="mt-3.5 overflow-x-auto whitespace-pre rounded border border-clef-border bg-clef-bg p-3 font-mono text-[11px] leading-relaxed text-clef-textSecondary"
          set:html={`<span class="text-clef-textMuted"># Initialise your repo</span>\n<span class="text-clef-accent">$</span> cd my-project &amp;&amp; clef init`}
        />
      </div>

      <!-- Step 2 -->
      <div class="bg-clef-panel p-8">
        <div
          class="mb-4 font-mono text-[11px] uppercase tracking-wider text-clef-accent"
        >
          02 — Manage
        </div>
        <svg
          class="mb-4 h-9 w-9 text-clef-accent"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
        <div class="mb-2.5 text-[17px] font-semibold text-clef-text">
          Set secrets via CLI or the local UI.
        </div>
        <p class="text-sm leading-relaxed text-clef-textSecondary">
          Use <code class="font-mono text-clef-accent">clef set</code> from the
          terminal, or run
          <code class="font-mono text-clef-accent">clef ui</code> for a
          full-featured browser interface at
          <code class="font-mono">127.0.0.1:7777</code>. Secrets are
          encrypted in place — never written to disk as plaintext.
        </p>
        <div
          class="mt-3.5 overflow-x-auto whitespace-pre rounded border border-clef-border bg-clef-bg p-3 font-mono text-[11px] leading-relaxed text-clef-textSecondary"
          set:html={`<span class="text-clef-textMuted"># Set a secret</span>\n<span class="text-clef-accent">$</span> clef set payments/staging STRIPE_KEY\n\n<span class="text-clef-textMuted"># Or open the UI</span>\n<span class="text-clef-accent">$</span> clef ui`}
        />
      </div>

      <!-- Step 3 -->
      <div class="bg-clef-panel p-8">
        <div
          class="mb-4 font-mono text-[11px] uppercase tracking-wider text-clef-accent"
        >
          03 — Validate
        </div>
        <svg
          class="mb-4 h-9 w-9 text-clef-accent"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path
            d="M22 11.08V12a10 10 0 1 1-5.93-9.14"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <polyline
            points="22 4 12 14.01 9 11.01"
            stroke-linecap="round"
            stroke-linejoin="round"></polyline>
        </svg>
        <div class="mb-2.5 text-[17px] font-semibold text-clef-text">
          Validate before you ship.
        </div>
        <p class="text-sm leading-relaxed text-clef-textSecondary">
          <code class="font-mono text-clef-accent">clef diff</code> compares
          keys across environments.
          <code class="font-mono text-clef-accent">clef lint</code> validates
          your entire matrix against schemas. Missing key in staging? You'll
          know before you ship.
        </p>
        <div
          class="mt-3.5 overflow-x-auto whitespace-pre rounded border border-clef-border bg-clef-bg p-3 font-mono text-[11px] leading-relaxed text-clef-textSecondary"
          set:html={`<span class="text-clef-textMuted"># Diff two environments</span>\n<span class="text-clef-accent">$</span> clef diff payments dev production\n\n<span class="text-clef-textMuted"># Lint the entire matrix</span>\n<span class="text-clef-accent">$</span> clef lint`}
        />
      </div>
    </div>
  </div>
</section>
