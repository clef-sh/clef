---
---

<section id="cta" class="border-t border-clef-border bg-clef-panel py-20">
  <div class="mx-auto max-w-[1200px] px-6">
    <div
      class="relative overflow-hidden rounded-[10px] border border-clef-borderMid bg-clef-surface px-12 py-14 text-center sm:px-12"
    >
      <!-- Gradient accent line at top -->
      <div
        class="absolute left-1/2 top-0 h-px w-80 -translate-x-1/2"
        style="background: linear-gradient(90deg, transparent, #F0A500, transparent);"
      >
      </div>

      <h2
        id="cta-heading"
        class="mb-3.5 text-[32px] font-bold tracking-tight text-clef-text"
      >
        Ready to manage secrets the right way?
      </h2>
      <p
        class="mx-auto mb-8 max-w-120 text-base leading-relaxed text-clef-textSecondary"
      >
        Stop decrypting files by hand. Clef gives your team a structured,
        auditable workflow for secrets — backed by git and encrypted by SOPS.
      </p>
      <a
        href="https://docs.clef.sh/guide/quick-start"
        class="inline-flex items-center gap-2 rounded-md border border-clef-accent bg-clef-accent px-7 py-3 text-[15px] font-semibold text-clef-bg transition-opacity hover:opacity-[0.88]"
      >
        Get Started
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
