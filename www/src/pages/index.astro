---
import "../styles/global.css";
import Hero from "../components/Hero.astro";
import StatsStrip from "../components/StatsStrip.astro";
import DocsPromo from "../components/DocsPromo.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Features from "../components/Features.astro";
import CtaSection from "../components/CtaSection.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Clef — Git-native secrets management for engineering teams</title>
    <meta
      name="description"
      content="Structure, schema enforcement, and drift detection for SOPS. Your secrets stay in your repo, encrypted by your KMS — inheriting your existing access controls and audit logs."
    />

    <!-- Open Graph -->
    <meta
      property="og:title"
      content="Clef — Git-native secrets management for engineering teams"
    />
    <meta
      property="og:description"
      content="Structure, schema enforcement, and drift detection for SOPS. Your secrets stay in your repo, encrypted by your KMS — inheriting your existing access controls and audit logs."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://clef.sh" />
    <meta property="og:image" content="https://clef.sh/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Clef — Git-native secrets management for engineering teams"
    />
    <meta
      name="twitter:description"
      content="Structure, schema enforcement, and drift detection for SOPS. Your secrets stay in your repo, encrypted by your KMS — inheriting your existing access controls and audit logs."
    />

    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', 'GTM-WZ3MH73K');
    </script>
    <!-- End Google Tag Manager -->

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Clef" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Noto+Music&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="min-h-screen bg-clef-bg font-sans text-clef-text antialiased"
    style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.025) 1px, transparent 0); background-size: 24px 24px;"
  >
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-WZ3MH73K"
        height="0"
        width="0"
        style="display: none; visibility: hidden"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a
      href="#main-content"
      class="absolute -top-full left-2 z-9999 rounded bg-clef-accent px-4 py-2 text-sm font-semibold text-clef-bg no-underline focus:top-2"
    >
      Skip to main content
    </a>

    <!-- Fixed Header -->
    <header
      class="fixed inset-x-0 top-0 z-50 flex h-14 items-center border-b border-clef-border bg-clef-panel/92 backdrop-blur-xl"
    >
      <div
        class="mx-auto flex w-full max-w-300 items-center justify-between px-6"
      >
        <a href="/" class="flex items-center text-clef-text no-underline">
          <img src="/clef.svg" alt="Clef logo" class="h-5 w-5" />
          <span class="text-[17px] font-semibold tracking-tight">Clef</span>
        </a>
        <a
          href="https://docs.clef.sh"
          class="rounded-md border border-clef-accent/30 px-3.5 py-1.5 text-[13px] font-medium text-clef-accent transition-all hover:border-clef-accent hover:bg-clef-accentDim"
        >
          Documentation
        </a>
      </div>
    </header>

    <!-- Trust Bar -->
    <div class="mt-14 border-b border-clef-border bg-clef-panel py-2.5">
      <div
        class="mx-auto flex max-w-300 items-center justify-between gap-4 px-6"
      >
        <div class="flex flex-wrap items-center gap-2">
          <span
            class="mr-1 font-mono text-[11px] font-medium uppercase tracking-widest text-clef-textMuted"
          >
            Built on SOPS
          </span>
          <span
            class="rounded border border-clef-border px-2.5 py-0.5 font-mono text-[11px] text-clef-textSecondary"
          >
            Git-native
          </span>
          <span
            class="rounded border border-clef-border px-2.5 py-0.5 font-mono text-[11px] text-clef-textSecondary"
          >
            Bring Your Own KMS
          </span>
          <span
            class="hidden rounded border border-clef-border px-2.5 py-0.5 font-mono text-[11px] text-clef-textSecondary sm:inline"
          >
            No vendor lock-in
          </span>
          <span
            class="hidden rounded border border-clef-border px-2.5 py-0.5 font-mono text-[11px] text-clef-accent sm:inline"
          >
            Clef Pro coming soon
          </span>
        </div>
        <a
          href="https://github.com/clef-sh/clef"
          class="flex items-center gap-1.5 whitespace-nowrap rounded border border-clef-border px-3 py-1.5 text-[13px] text-clef-textSecondary no-underline transition-colors hover:border-clef-borderMid hover:text-clef-text"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            aria-hidden="true"
          >
            <path
              d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
            ></path>
          </svg>
          View on GitHub
        </a>
      </div>
    </div>

    <main id="main-content">
      <Hero />
      <StatsStrip />
      <DocsPromo />
      <HowItWorks />
      <Features />

      <!-- Broker Registry callout -->
      <section class="border-t border-clef-border py-16" aria-label="Broker Registry">
        <div class="mx-auto max-w-300 px-6">
          <div class="mb-10">
            <div
              class="mb-3 font-mono text-[11px] font-medium uppercase tracking-widest text-clef-accent"
            >
              Dynamic Credentials
            </div>
            <h2 class="mb-2.5 text-[32px] font-bold tracking-tight text-clef-text">
              Broker Registry
            </h2>
            <p class="max-w-prose text-[15px] leading-relaxed text-clef-textSecondary">
              Short-lived credentials generated on demand. Install a broker template, deploy it as a
              Lambda or container, and the Clef agent handles the rest &mdash; polling, KMS
              unwrapping, caching, and serving. Your <code class="font-mono text-clef-accent">create()</code> function
              is the only code you write.
            </p>
          </div>

          <div class="grid gap-px overflow-hidden rounded-[10px] border border-clef-border bg-clef-border sm:grid-cols-2 lg:grid-cols-4">
            <div class="bg-clef-panel p-6">
              <div class="mb-1 font-mono text-[11px] font-medium text-clef-accent">AWS</div>
              <div class="mb-1 text-sm font-semibold text-clef-text">sts-assume-role</div>
              <p class="text-[12px] leading-relaxed text-clef-textSecondary">Temporary AWS credentials via STS. 25 lines.</p>
            </div>
            <div class="bg-clef-panel p-6">
              <div class="mb-1 font-mono text-[11px] font-medium text-clef-accent">AWS</div>
              <div class="mb-1 text-sm font-semibold text-clef-text">rds-iam</div>
              <p class="text-[12px] leading-relaxed text-clef-textSecondary">RDS IAM auth tokens with 15-min TTL. 15 lines.</p>
            </div>
            <div class="bg-clef-panel p-6">
              <div class="mb-1 font-mono text-[11px] font-medium text-clef-accent">Agnostic</div>
              <div class="mb-1 text-sm font-semibold text-clef-text">oauth-client-credentials</div>
              <p class="text-[12px] leading-relaxed text-clef-textSecondary">One broker for every OAuth2 SaaS API. 30 lines.</p>
            </div>
            <div class="bg-clef-panel p-6">
              <div class="mb-1 font-mono text-[11px] font-medium text-clef-accent">Agnostic</div>
              <div class="mb-1 text-sm font-semibold text-clef-text">sql-database</div>
              <p class="text-[12px] leading-relaxed text-clef-textSecondary">Ephemeral SQL users for Postgres, MySQL, MSSQL. 40 lines.</p>
            </div>
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-4">
            <a
              href="https://registry.clef.sh"
              class="inline-flex items-center gap-2 rounded-md border border-clef-accent px-5 py-2.5 text-sm font-semibold text-clef-accent no-underline transition-colors hover:bg-clef-accent hover:text-clef-bg"
            >
              Browse the registry
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </a>
            <span class="text-[13px] text-clef-textSecondary">
              or run <code class="rounded bg-clef-surface px-2 py-0.5 font-mono text-[12px] text-clef-accent">clef search</code> from the terminal
            </span>
          </div>
        </div>
      </section>

      <!-- Whitepaper callout -->
      <section class="border-t border-clef-border py-10" aria-label="Whitepaper">
        <div class="mx-auto max-w-300 px-6">
          <div
            class="grid items-center gap-8 rounded-[10px] border border-clef-borderMid bg-clef-panel px-8 py-7 sm:grid-cols-[1fr_auto]"
          >
            <div>
              <div
                class="mb-1 font-mono text-[11px] font-medium uppercase tracking-widest text-clef-accent"
              >
                Whitepaper
              </div>
              <div class="mb-1.5 text-[17px] font-semibold text-clef-text">
                Read the Clef whitepaper
              </div>
              <p class="text-sm leading-relaxed text-clef-textSecondary">
                A deep dive into the architecture, security model, and design
                decisions behind git-native secrets management with Clef.
              </p>
            </div>
            <a
              href="https://github.com/clef-sh/clef/blob/main/whitepaper.md"
              class="inline-flex shrink-0 items-center gap-2 rounded-md border border-clef-borderMid bg-transparent px-5 py-2.5 text-[13px] font-semibold text-clef-textSecondary no-underline transition-colors hover:border-clef-textSecondary hover:text-clef-text"
            >
              Read whitepaper
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
                ></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
            </a>
          </div>
        </div>
      </section>

      <CtaSection />
    </main>
    <Footer />
  </body>
</html>
