{
  "name": "clef",
  "version": "0.0.0",
  "private": true,
  "description": "Git-native config and secrets management built on Mozilla SOPS",
  "workspaces": [
    "packages/design",
    "packages/core",
    "packages/analytics",
    "packages/client",
    "packages/runtime",
    "packages/cloud",
    "packages/ui",
    "packages/broker",
    "packages/agent",
    "packages/cdk",
    "packages/pack/*",
    "packages/cli",
    "www",
    "registry"
  ],
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:integration": "cd integration && npm test",
    "test:e2e": "npm run build && npm run build:sea -w packages/cli && cd e2e && npm ci && npx playwright install --with-deps chromium && npx playwright test",
    "test:e2e:node": "npm run build && cd e2e && npm ci && npx playwright install --with-deps chromium && CLEF_E2E_MODE=node npx playwright test",
    "format": "prettier --write . && npm run format --workspaces --if-present",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "build": "npm run build --workspaces",
    "docs:api": "typedoc",
    "docs:build": "npm run docs:api && vitepress build docs",
    "docs:dev": "npm run docs:api && vitepress dev docs",
    "registry:dev": "cd registry && npm run dev",
    "registry:build": "cd registry && npm run build",
    "prepublishOnly": "npm run build",
    "publish": "npm publish --workspaces --if-present"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clef-sh/clef.git"
  },
  "homepage": "https://clef.sh",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "esbuild": "0.28.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.39.0",
    "prettier": "^3.8.3",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "overrides": {
    "axios": "^1.15.0"
  }
}
