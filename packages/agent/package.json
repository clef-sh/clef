{
  "name": "@clef-sh/agent",
  "version": "0.1.13-alpha.90",
  "description": "Runtime secrets sidecar agent for Clef",
  "repository": {
    "type": "git",
    "url": "https://github.com/clef-sh/clef",
    "directory": "packages/agent"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clef-agent": "dist/agent.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:sea": "node scripts/build.mjs --sea",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "npx tsx --test e2e/agent.e2e.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.500.0",
    "@azure/identity": "^4.0.0",
    "@azure/keyvault-keys": "^4.8.0",
    "@google-cloud/kms": "^4.0.0",
    "@clef-sh/runtime": "*",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "esbuild": "^0.27.4",
    "jest": "^29.7.0",
    "postject": "^1.0.0-alpha.6",
    "ts-jest": "^29.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT"
